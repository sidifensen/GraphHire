# 数据库配置
DB_URL=jdbc:postgresql://localhost:5432/graphhire
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_api_key_here
