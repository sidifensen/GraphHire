# RocketMQ 配置
ROCKETMQ_NAMESERVER=localhost:9876

# RustFS 配置
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=your_rustfs_access_key
RUSTFS_SECRET_KEY=your_rustfs_secret_key
RUSTFS_BUCKET=resumes
